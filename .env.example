# Telegram Bot Token (получить у @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Google Gemini API Key (получить в Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# ID администраторов (через запятую, если несколько)
ADMIN_IDS=123456789

# База данных (можно оставить SQLite для старта)
DATABASE_URL=sqlite+aiosqlite:///./gemini_bot.db

# Лимиты для пользователей
MAX_REQUESTS_PER_DAY=50
MAX_REQUESTS_PER_HOUR=10

# Настройки изображений
DEFAULT_ASPECT_RATIO=1:1

# Логирование
LOG_LEVEL=INFO
